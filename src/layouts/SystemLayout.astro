---
import DesktopToolbar from "@/components/DesktopToolbar";
import MobileClock from "@/components/MobileClock";
import MobileNavPill from "@/components/MobileNavPill";
import styles from "@/app/(system)/system-layout.module.css";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<main class={styles.main}>
  <MobileClock client:load />
  <div class={styles.monitorFrame}>
    <div class={styles.monitorScreen}>
      <DesktopToolbar pathname={pathname} client:load />
      <div class={styles.monitorContent}>
        <slot />
      </div>
    </div>
    <div class={styles.monitorStand}></div>
    <div class={styles.monitorBase}></div>
  </div>
  <MobileNavPill pathname={pathname} client:load />
</main>
