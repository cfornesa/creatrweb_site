{
  "name": "creatrweb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx --watch server.ts",
    "build": "esbuild server.ts --bundle --platform=node --target=node20 --format=esm --external:better-sqlite3 --external:fsevents --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --outfile=server.bundle.js",
    "start": "HOST=0.0.0.0 node server.bundle.js",
    "rag:index": "tsx scripts/rag-index.ts"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.5",
    "tsx": "4.21.0",
    "typescript": "^6.0.2"
  }
}
